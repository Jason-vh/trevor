# Written by .github/workflows/deploy.yml from GitHub Actions secrets.
# This file shows the shape only — never commit real values.

# App / runtime
NODE_ENV=production
TZ=Europe/Amsterdam

# Database (shared Postgres on vhtm-eu)
DATABASE_URL=postgresql://trevor:replace-me@postgres:5432/trevor

# Telegram bot
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_CHAT_ID=comma,separated,ids

# Webhook mode (production only — Telegram POSTs to https://${WEBHOOK_DOMAIN}/webhook)
WEBHOOK_DOMAIN=trevor.vhtm.eu
WEBHOOK_SECRET=replace-me

# AI
ANTHROPIC_API_KEY=replace-me

# SquashCity
SQUASH_CITY_USERNAME=replace-me
SQUASH_CITY_PASSWORD=replace-me

# Logging
AXIOM_TOKEN=replace-me

# Google Calendar (optional — omit to disable)
CALENDAR_WEBHOOK_URL=

# Compose
TREVOR_APP_HOST_PORT=3007
COMPOSE_PROJECT_NAME=trevor
